{
  "name": "jimblogic-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-build-version.mjs",
    "build": "vite build && npm run purgecss",
    "preview": "vite preview --port 4173",
    "lint": "eslint assets/js scripts tests --ext .js,.mjs,.ts && stylelint \"style.css\"",
    "format": "prettier --write .",
    "audit": "echo Run Lighthouse CI locally if installed",
    "to:webp": "echo Add cwebp conversion here if installed",
    "purgecss": "echo \"Skip PurgeCSS (handled by Vite/CSS splitting)\"",
    "test": "npm run lint && npm run build && npm run validate:local",
    "validate:local": "node scripts/validate-local.mjs --dist-dir dist",
    "audit:production": "node scripts/audit-production.mjs",
    "test:unit": "npm run validate:local",
    "test:e2e": "playwright test",
    "test:e2e:local": "npm run build && playwright test",
    "test:e2e:ci": "playwright test --project=chromium",
    "validate:version": "node scripts/validate-build-version-canonical.mjs --dist-dir dist",
    "validate:privacy": "node scripts/validate-artifact-privacy.mjs --dist-dir dist"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@playwright/test": "1.56.1",
    "@testing-library/dom": "10.4.1",
    "autoprefixer": "10.4.22",
    "eslint": "9.39.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.4",
    "playwright": "1.56.1",
    "postcss": "8.5.14",
    "prettier": "3.6.2",
    "purgecss": "6.0.0",
    "stylelint": "16.25.0",
    "stylelint-config-standard": "36.0.1",
    "svgo": "3.3.3",
    "vite": "8.0.13",
    "vite-plugin-static-copy": "4.1.0",
    "vitest": "4.1.6"
  }
}
